# MongoDB Atlas (required in production)
# Database name only — do NOT append collection paths like /.users or /users
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/allowanceAI?retryWrites=true&w=majority

# Auth
JWT_SECRET=your-long-random-secret-min-32-chars

# Frontend URL(s) — comma-separated for multiple origins (Vercel production + preview)
CLIENT_URL=https://allowance-ai-eight.vercel.app,http://localhost:5173

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://allowanceai-api.onrender.com/api/auth/google/callback

# Email (password reset)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_SERVICE=gmail

# AI microservice (Render Python service URL)
AI_SERVICE_URL=https://allowanceai-ai.onrender.com

# Server
PORT=5000
NODE_ENV=production
